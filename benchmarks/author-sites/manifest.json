      "tags": ["ambiguous", "fallback-negative", "sparse"],
      "baseUrl": "https://sol-sparse.author.test/",
      "pages": [
        {
          "path": "/",
          "fixture": "fixtures/sparse-ssr.html",
          "expectedPrimaryRole": "HOME",
          "expectedFallback": { "triggerCodes": [] }
        }
      ],
      "expectedSignals": {
        "authorBrand.clearHomepageHeadline": true,
        "seo.titleTagExists": true,
        "seo.metaDescriptionExists": true,
        "seo.h1Exists": true
      },
      "expectedOutcomes": {
        "search.home_title": "present",
        "search.home_meta_description": "present",
        "search.home_h1": "present"
      }
    },
    {
      "id": "javascript-shell-hydrated",
      "description": "A JavaScript application shell is rendered and the richer extraction is adopted.",
      "tags": ["positive", "dynamic", "browser-fallback"],
      "baseUrl": "https://aria-dynamic.author.test/",
      "pages": [
        {
          "path": "/",
          "fixture": "fixtures/js-shell-static.html",
          "renderedFixture": "fixtures/js-shell-rendered.html",
          "expectedPrimaryRole": "HOME",
          "expectedFallback": {
            "triggerCodes": ["empty_application_root", "javascript_required_noscript"],
            "adopted": true
          }
        }
      ],
      "expectedSignals": {
        "authorBrand.clearHomepageHeadline": true,
        "newsletter.newsletterSignupForm": true,
        "newsletter.emailInput": true,
        "seo.h1Exists": true
      },
      "expectedOutcomes": {
        "engagement.newsletter_signup": "present",
        "search.home_title": "present",
        "search.home_h1": "present"
      }
    },
    {
      "id": "widget-render-no-material-gain",
      "description": "A rendered widget response that adds no useful evidence is not adopted.",
      "tags": ["negative", "dynamic", "browser-fallback"],
      "baseUrl": "https://tomas-widget.author.test/",
      "pages": [
        {
          "path": "/",
          "fixture": "fixtures/widget-static.html",
          "renderedFixture": "fixtures/widget-rendered-no-gain.html",
          "expectedPrimaryRole": "HOME",
          "expectedFallback": {
            "triggerCodes": ["unresolved_widget_placeholder"],
            "adopted": false
          }
        }
      ],
      "expectedSignals": {
        "newsletter.newsletterSignupForm": false,
        "newsletter.emailInput": false
      }
    },
