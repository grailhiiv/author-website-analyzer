      "baseUrl": "https://member-login.author.test/",
      "pages": [
        { "path": "/login", "fixture": "fixtures/login-email-trap.html", "expectedPrimaryRole": "UNKNOWN" }
      ],
      "expectedSignals": {
        "newsletter.newsletterSignupForm": false,
        "newsletter.subscribeForm": false,
        "newsletter.emailInput": true,
        "trust.contactForm": false
      },
      "expectedOutcomes": { "engagement.newsletter_signup": "absent" },
